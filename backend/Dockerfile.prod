FROM node:22-alpine AS deps

WORKDIR /app
COPY package*.json ./
RUN npm ci --omit=dev

FROM node:22-alpine

ENV NODE_ENV=production
WORKDIR /app

RUN addgroup -S authsphere && adduser -S authsphere -G authsphere

COPY --from=deps /app/node_modules ./node_modules
COPY . .

USER authsphere
EXPOSE 5000

CMD ["npm", "start"]

